{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IoT NAC V1 测试用例 Schema",
  "description": "V1 简化版测试用例格式，仅含 title/steps/assertions 三个核心字段",
  "type": "object",
  "required": ["title", "steps"],
  "properties": {
    "title": {
      "type": "string",
      "description": "测试用例标题"
    },
    "description": {
      "type": "string",
      "description": "测试用例详细描述（可选）"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "target", "action"],
        "properties": {
          "description": {
            "type": "string",
            "description": "步骤的自然语言描述"
          },
          "target": {
            "type": "string",
            "enum": ["web", "desktop", "ssh", "controller", "switch"],
            "description": "操作目标：web(浏览器) / desktop(客户端) / ssh(远程执行)"
          },
          "action": {
            "type": "string",
            "enum": ["navigate", "click", "input", "select", "execute", "screenshot", "wait", "hotkey", "check", "scroll"],
            "description": "操作类型"
          },
          "params": {
            "type": "object",
            "description": "操作参数（因 action 而异）"
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "预期断言列表（自然语言描述）"
    }
  }
}
